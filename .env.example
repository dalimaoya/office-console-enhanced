# ─────────────────────────────────────────────────────────────────────────────
# office-dashboard-adapter — 环境变量说明
# 复制此文件为 .env 并按需修改
# ─────────────────────────────────────────────────────────────────────────────

# ── 基础服务配置 ─────────────────────────────────────────────────────────────

# HTTP 监听端口，默认 3014
PORT=3014

# HTTP 监听地址，默认 0.0.0.0
HOST=0.0.0.0

# 命令超时（ms），默认 10000
COMMAND_TIMEOUT_MS=10000

# 健康检查超时（ms），默认 1500
HEALTH_TIMEOUT_MS=1500

# ── Gateway 连接配置 ─────────────────────────────────────────────────────────

# Gateway HTTP 健康检查 URL
GATEWAY_HEALTH_URL=http://127.0.0.1:18789/health

# Gateway WebSocket URL
GATEWAY_WS_URL=ws://127.0.0.1:18789

# Gateway Token（可选，与 openclaw gateway 配置一致）
OC_GATEWAY_TOKEN=

# Gateway WS 重连间隔（ms），默认 3000
GATEWAY_WS_RECONNECT_MS=3000

# ── 数据层配置（Iter-1）────────────────────────────────────────────────────

# 是否优先使用文件直读路径（true/false），默认 true
USE_FILE_READER=true

# OpenClaw 根目录，默认 ~/.openclaw
OPENCLAW_ROOT=

# SSE 心跳间隔（ms），默认 25000
SSE_HEARTBEAT_INTERVAL_MS=25000

# 项目根目录（FileWatcher 监控范围）
PROJECT_ROOT=

# ── 安全框架配置（Iter-2）────────────────────────────────────────────────────

# 只读模式（true/false），默认 true（安全优先）
# 设为 false 才允许写操作（POST/PUT/PATCH/DELETE）
READONLY_MODE=true

# 本地控制台 Token（可选）
# 设置后，所有 API 请求需携带 Authorization: Bearer <token> 或 X-Console-Token: <token>
OC_CONSOLE_TOKEN=

# 写操作默认 dry-run（true/false），默认 true（安全优先）
# 设为 false 后，客户端不指定 dryRun 时默认真实执行
OC_DRY_RUN_DEFAULT=true

# 允许写入的 IP 白名单（逗号分隔），默认仅 localhost
OC_ALLOWED_WRITE_ORIGINS=127.0.0.1,::1

# 审计日志目录
AUDIT_LOG_DIR=

# ── 模板配置（Iter-3）────────────────────────────────────────────────────────

# 模板目录，默认 src/templates/
TEMPLATES_DIR=

# ── 飞书通知配置（Iter-6）────────────────────────────────────────────────────

# 飞书 Bot Webhook URL（可选）
# 获取方式：飞书群 -> 群设置 -> 群机器人 -> 添加自定义机器人 -> 复制 Webhook URL
# 格式：https://open.feishu.cn/open-apis/bot/v2/hook/<UUID>
# 未设置时不推送飞书通知
FEISHU_WEBHOOK_URL=

# 触发通知的事件类型：
#   - agent.status (offline/error)：Agent 状态异常
#   - task.status (blocked)：任务被阻塞

# ── 开发调试配置 ──────────────────────────────────────────────────────────────

# 模拟 Gateway 模式（开发用，设为非空值启用）
MOCK_GATEWAY_MODE=

# 模拟 config apply 失败（开发用，设为非空值启用）
MOCK_CONFIG_APPLY_FAILURE=
